# ─────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno para DiveConnect
# Copia este fichero a .env y rellena los valores reales.
# El .env real NUNCA se commitea (está en .gitignore).
# ─────────────────────────────────────────────────────────────────

# ─── Base de datos ───────────────────────────────────────────────
DB_USERNAME=diveconnect_user
DB_PASSWORD=DiveConnect2025!

# ─── Seguridad JWT (mínimo 32 caracteres en producción) ──────────
JWT_SECRET=DiveConnect2025SecretKeyForJWTTokenGenerationMustBeLongEnoughToBeSecure

# ─── URL del frontend (para el success_url de Stripe) ────────────
FRONTEND_URL=http://localhost:8080

# ─── Stripe (dejar vacío para modo demo) ─────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ─── PayPal (dejar vacío para modo demo) ─────────────────────────
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─── Google OAuth2 ───────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_ENABLED=false

# ─── OpenWeatherMap (opcional) ───────────────────────────────────
# https://openweathermap.org/api
OPENWEATHER_API_KEY=
